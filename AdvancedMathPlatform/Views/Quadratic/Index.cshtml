@model AdvancedMathPlatform.Models.MathViewModel

@{
    ViewData["Title"] = "Ecuații de Gradul II";
}

<div id="welcomeBlock">
    <h2>Ecuații de Gradul II</h2>
    <p>Introduceți ecuația de forma <strong>ax² + bx + c = 0</strong> și apăsați <em>Calculează</em>.</p>
    <p style="opacity:0.7; font-size:0.9em;">Exemplu: <code>x^2-4x+4=0</code> &nbsp;|&nbsp; <code>2x^2+3x-5=0</code> &nbsp;|&nbsp; <code>x^2+1=0</code></p>
</div>

<div id="workArea">
    <form asp-controller="Quadratic" asp-action="Calculate" method="post">
        <div class="input-section">

            <label for="equationInput">Introduceți ecuația:</label>
            <input id="equationInput" type="text" name="Equation"
                   value="@Model.Equation" placeholder="ex: x^2-4x+4=0" autocomplete="off" />

            <label style="margin-top:14px;">Limbă / Language / Язык:</label>
            <div class="lang-selector">
                <label class="lang-option @(Model.Language == "Română" || Model.Language == null ? "lang-selected" : "")">
                    <input type="radio" name="Language" value="Română"
                    @(Model.Language == "Română" || Model.Language == null ? "checked" : "") />
                    🇷🇴 Română
                </label>
                <label class="lang-option @(Model.Language == "English" ? "lang-selected" : "")">
                    <input type="radio" name="Language" value="English"
                    @(Model.Language == "English" ? "checked" : "") />
                    🇬🇧 English
                </label>
                <label class="lang-option @(Model.Language == "Russian" ? "lang-selected" : "")">
                    <input type="radio" name="Language" value="Russian"
                    @(Model.Language == "Russian" ? "checked" : "") />
                    🇷🇺 Русский
                </label>
            </div>

            <button type="submit">Calculează</button>
        </div>
    </form>

    @if (Model.ParseError != null)
    {
        <div class="result-section error-section">
            <span class="error-icon">⚠️</span> @Model.ParseError
        </div>
    }

    @if (Model.Steps.Any())
    {
        <div class="lang-badge">@Model.LanguageFlag @Model.Language</div>

        <div class="result-section">
            @foreach (var step in Model.Steps)
            {
                if (step.StartsWith("─"))
                {
                    <div class="step-divider"></div>
                }
                else if (step.TrimStart().StartsWith("x =") || step.TrimStart().StartsWith("x₁") || step.TrimStart().StartsWith("x₂"))
                {
                    <p class="step-answer">@step</p>
                }
                else if (step.TrimStart().StartsWith("Δ ="))
                {
                    <p class="step-delta">@step</p>
                }
                else
                {
                    <p>@step</p>
                }
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        window.onload = function () {
            document.getElementById("welcomeBlock").style.display = "block";
            document.getElementById("workArea").style.display = "block";

            document.querySelectorAll('.lang-option input').forEach(function(radio) {
                radio.addEventListener('change', function() {
                    document.querySelectorAll('.lang-option').forEach(l => l.classList.remove('lang-selected'));
                    this.parentElement.classList.add('lang-selected');
                });
            });
        };
    </script>
}
