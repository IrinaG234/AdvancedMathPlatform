@model AdvancedMathPlatform.Models.MathViewModel

@{
    ViewData["Title"] = "Ecuații de Gradul I";
}

<div id="welcomeBlock">
    <h2>Ecuații de Gradul I</h2>
    <p>Introduceți ecuația de forma <strong>ax + b = 0</strong> și apăsați <em>Calculează</em>.</p>
    <p style="opacity:0.7; font-size:0.9em;">Exemplu: <code>2x+6=0</code> &nbsp;|&nbsp; <code>-3x+9=0</code> &nbsp;|&nbsp; <code>5x-10=0</code></p>
</div>

<div id="workArea">
    <form asp-controller="Linear" asp-action="Calculate" method="post">
        <div class="input-section">
            <label for="equationInput">Introduceți ecuația:</label>
            <input id="equationInput"
                   type="text"
                   name="Equation"
                   value="@Model.Equation"
                   placeholder="ex: 2x+6=0"
                   autocomplete="off" />
            <button type="submit">Calculează</button>
        </div>
    </form>

    @if (Model.ParseError != null)
    {
        <div class="result-section error-section">
            <span class="error-icon">⚠️</span> @Model.ParseError
        </div>
    }

    @if (Model.Steps.Any())
    {
        <div class="result-section">
            @foreach (var step in Model.Steps)
            {
                if (step.StartsWith("─"))
                {
                    <div class="step-divider"></div>
                }
                else if (step.TrimStart().StartsWith("x ="))
                {
                    <p class="step-answer">@step</p>
                }
                else
                {
                    <p>@step</p>
                }
            }
        </div>
    }
</div>

@section Scripts {
    <script>
        // Această pagină MVC nu folosește showWelcome() din JS-ul vechi.
        // Suprascriem funcția ca să nu ascundă workArea.
        window.onload = function () {
            document.getElementById("welcomeBlock").style.display = "block";
            document.getElementById("workArea").style.display  = "block";
        };
    </script>
}
