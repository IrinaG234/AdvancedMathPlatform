<!DOCTYPE html>
<html lang="ro">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"] - TeachMATH</title>
    <link rel="stylesheet" href="~/css/AMP_style.css" />
</head>
<body>

    <div class="dashboard">

        <!-- LEFT SIDEBAR -->
        <aside class="sidebar">
            <h2 class="logo">
                <a asp-controller="Home" asp-action="Index">TeachMATH</a>
            </h2>

            <div class="menu">

                <h3>📚 Gimnaziu</h3>
                <ul>
                    <li><a asp-controller="Zecimale" asp-action="Index">Zecimale</a></li>
                    <li><a asp-controller="Functii" asp-action="Index">Functii</a></li>
                    <li><a asp-controller="OperatiiFractii" asp-action="Index">Operatii cu Fractii</a></li>
                    <li><a asp-controller="Linear" asp-action="Index">Ecuatii grad I</a></li>
                    <li><a asp-controller="Quadratic" asp-action="Index">Ecuatii grad II</a></li>
                    <li><a asp-controller="SistemEcuatii" asp-action="Index">Sistem de ecuatii</a></li>
                    <li><a asp-controller="Proportii" asp-action="Index">Proportii</a></li>
                    <li><a asp-controller="Pitagora" asp-action="Index">Teorema lui Pitagora</a></li>
                    <li><a asp-controller="AriaPerimetru" asp-action="Index">Aria si Perimetrul</a></li>
                </ul>

                <h3>🎓 Liceu</h3>
                <ul>
                    <li><a asp-controller="Matrici" asp-action="Index">Matrici</a></li>
                    <li><a asp-controller="Determinanti" asp-action="Index">Determinanti</a></li>
                    <li><a asp-controller="Probabilitati" asp-action="Index">Probabilitati</a></li>
                    <li><a asp-controller="Logaritmi" asp-action="Index">Logaritmi</a></li>
                    <li><a asp-controller="ProgresieAritmetica" asp-action="Index">Progresie aritmetica</a></li>
                    <li><a asp-controller="FunctiiAvansate" asp-action="Index">Functii avansate</a></li>
                </ul>

            </div>
        </aside>

        <!-- CENTER CONTENT -->
        <main class="main">
            @RenderBody()
        </main>

        <!-- RIGHT SIDEBAR -->
        <aside class="right-panel">
            <div class="profile-card">
                <div class="avatar">👩‍🎓</div>
                <h3>Irina Glodin</h3>
                <p class="email">irina@email.com</p>
                <div class="profile-buttons">
                    <button class="btn edit">Edit Profile</button>
                    <button class="btn logout">Logout</button>
                </div>
            </div>
            <div class="history-section">
                <h3>🕘 History</h3>
                <div id="historyContainer"></div>
            </div>
        </aside>

    </div>

    <script src="~/js/AMP_script.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
